[filechooser]
# Wrapper custom (bin/yazi-portal-wrapper) que usa `hyprctl dispatch exec
# [float;size...;center;opacity]` para que kitty abra directo flotante en
# posición — sin flicker. Además limpia chooser-file en cancel/SIGTERM.
cmd=/home/calvin/.local/bin/yazi-portal-wrapper

default_dir=$HOME

# create_help_file=0 evita generar archivos placeholder con instrucciones
create_help_file=0

# Modos: 'suggested' = usar el path que la app sugirió, 'default' = default_dir
open_mode=suggested
save_mode=suggested
