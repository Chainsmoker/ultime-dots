# GENERADO POR MATUGEN — no editar a mano.
# Colores de fzf derivados del wallpaper (Material You). La zshrc añade estos
# flags a $FZF_DEFAULT_OPTS. `bg:-1`/`gutter:-1` usan el fondo del terminal para
# respetar la transparencia de kitty.
export FZF_THEME_COLORS="\
--color=fg:#{{colors.on_surface.default.hex_stripped}},fg+:#{{colors.on_background.default.hex_stripped}},bg:-1,bg+:#{{colors.surface_container.default.hex_stripped}} \
--color=hl:#{{colors.tertiary.default.hex_stripped}},hl+:#{{colors.primary.default.hex_stripped}},gutter:-1 \
--color=info:#{{colors.secondary.default.hex_stripped}},border:#{{colors.primary.default.hex_stripped}},separator:#{{colors.outline.default.hex_stripped}} \
--color=prompt:#{{colors.primary.default.hex_stripped}},pointer:#{{colors.tertiary.default.hex_stripped}},marker:#{{colors.tertiary.default.hex_stripped}} \
--color=spinner:#{{colors.secondary.default.hex_stripped}},header:#{{colors.secondary.default.hex_stripped}},label:#{{colors.primary.default.hex_stripped}},query:#{{colors.on_background.default.hex_stripped}}"
