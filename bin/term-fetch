#!/usr/bin/env bash
# term-fetch — entrypoint del arte en terminal usado en el startup de zsh
# (config/zsh-custom/term-art.zsh lo llama dentro de kitty).
#
# Hoy es idéntico a `term-art` (imagen sola). Antes era una copia byte-a-byte;
# se unificó para que la lógica viva en un solo lugar. Si en el futuro querés
# agregar info del sistema debajo de la imagen, reemplazá el exec por algo como:
#     term-art "$@" && neofetch
exec term-art "$@"
